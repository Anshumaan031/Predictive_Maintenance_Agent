# === Required ===
CONTEXT_RETRIEVER_AGENT_KEY=your-context-retriever-agent-key

# === LLM Provider — pick one block ===

# Anthropic
PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6
API_KEY=sk-ant-...

# OpenAI
# PROVIDER=openai
# MODEL_NAME=gpt-4o
# API_KEY=sk-...

# Google
# PROVIDER=google
# MODEL_NAME=gemini-2.5-pro
# API_KEY=AIza...

# OpenRouter
# PROVIDER=openrouter
# MODEL_NAME=meta-llama/llama-3.3-70b-instruct
# API_KEY=sk-or-...

# === Agent Memory (optional — set all three to enable) ===
AGENT_MEMORY_ENDPOINT=
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_KEY=

# === Redis (needed for write-back tools and crestforge scripts) ===
# When running via docker-compose this is overridden automatically.
REDIS_URL=redis://localhost:6379

# === CrestForge setup scripts only ===
CTX_ADMIN_KEY=

# === Optional overrides ===
# CTX_MCP_URL=https://gcp-us-east4.context-surfaces.redis.io/mcp
# OWNER_ID=machine-floor
# SESSION_ID=session-1
